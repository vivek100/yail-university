FROM public.ecr.aws/docker/library/python:3.11-bookworm

WORKDIR /app

# Install common analysis tools
RUN apt-get update && apt-get install -y \
    git \
    jq \
    ripgrep \
    && rm -rf /var/lib/apt/lists/*

# Create workspace directory for trace data
RUN mkdir -p /workspace && chmod 777 /workspace

# Install Python dependencies
COPY pyproject.toml README.md ./
RUN pip install --no-cache-dir .

# Copy environment code
COPY env.py qa_common.py qa_*.py ./

# Run the v6 environment control channel.
CMD ["hud", "serve", "env:env", "--host", "0.0.0.0"]
