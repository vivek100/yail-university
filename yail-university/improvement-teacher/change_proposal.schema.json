{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yail.local/schemas/change_proposal.schema.json",
  "title": "YAIL Improvement Teacher Change Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "change_id",
    "parent_versions",
    "target",
    "failure_evidence",
    "proposed_change",
    "files_to_change",
    "risk",
    "validation_plan",
    "promotion_rule"
  ],
  "properties": {
    "change_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "parent_versions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["student", "environment", "taskset"],
      "properties": {
        "student": {"type": "string"},
        "environment": {"type": "string"},
        "taskset": {"type": "string"}
      }
    },
    "target": {
      "type": "string",
      "enum": ["agent_config", "environment", "task", "grader", "curriculum", "dataset"]
    },
    "failure_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["trace_id", "task_id", "evidence", "fault"],
        "properties": {
          "trace_id": {"type": "string"},
          "task_id": {"type": "string"},
          "reward": {"type": ["number", "null"]},
          "qa_finding": {"type": "string"},
          "evidence": {"type": "string"},
          "fault": {
            "type": "string",
            "enum": ["agent", "eval", "platform", "unclear"]
          }
        }
      }
    },
    "proposed_change": {
      "type": "string",
      "minLength": 20
    },
    "files_to_change": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "patch_summary": {
      "type": "string"
    },
    "risk": {
      "type": "string",
      "minLength": 10
    },
    "validation_plan": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "promotion_rule": {
      "type": "string",
      "minLength": 20
    },
    "rejection_conditions": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
